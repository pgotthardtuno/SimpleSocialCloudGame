// tsconfig.json
{
  "compilerOptions": {
    "target": "ES2016", // Or newer
    "module": "CommonJS",
    "outDir": "./dist", // Output directory for compiled JavaScript
    "rootDir": "./src", // Source directory for TypeScript files
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node", // Add this line
    "resolveJsonModule": true // If you plan to import JSON files
  },
  "include": ["src/**/*"], // Files to include in compilation
  "exclude": ["node_modules"] // Folders to exclude
}